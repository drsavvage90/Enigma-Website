# Site URL (used for canonical URLs, OG tags, sitemap)
VITE_SITE_URL=https://www.enigmasoftwaresystems.com

# Sentry DSN for error monitoring (optional)
VITE_SENTRY_DSN=

# Analytics — set one or both (optional)
# Plausible: privacy-friendly, no cookies, GDPR-compliant (< 1 KB)
VITE_PLAUSIBLE_DOMAIN=enigmasoftwaresystems.com
# Google Analytics 4: set your measurement ID (G-XXXXXXXXXX)
VITE_GA4_ID=

# Google Search Console verification token
# GOOGLE_SITE_VERIFICATION=

# Bing Webmaster verification token
# BING_VERIFICATION=
